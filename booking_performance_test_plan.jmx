            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import org.apache.commons.lang3.RandomStringUtils
import groovy.json.JsonBuilder

def itemName = RandomStringUtils.randomAlphabetic(10)
def itemDescription = RandomStringUtils.randomAlphabetic(35)

def newItem = [
    itemName: itemName,
    itemDescription: itemDescription
]

def newItemJson = new JsonBuilder(newItem).toPrettyString()
vars.put(&quot;newItemJson&quot;, newItemJson)</stringProp>
