        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Randomize Variables" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import org.apache.commons.lang3.RandomStringUtils
import java.time.LocalDateTime
import java.util.Random
import groovy.json.JsonOutput

vars.put(&quot;itemsJson&quot;, JsonOutput.toJson([]))

def collectionTypes = [&quot;HOME&quot;, &quot;COLLECTION_POINT&quot;]
def paymentMethods = [&quot;CREDIT_CARD&quot;, &quot;PAYPAL&quot;, &quot;BANK_TRANSFER&quot;, &quot;CASH&quot;, &quot;VISA&quot;, &quot;MASTER&quot;, &quot;PAYNOW&quot;, &quot;PAYLAH&quot;]
def random = new Random()

def selectedCollectionType = collectionTypes[random.nextInt(collectionTypes.size())]
def selectedPaymentMethod = paymentMethods[random.nextInt(paymentMethods.size())]

vars.put(&quot;collectionType&quot;, selectedCollectionType)
vars.put(&quot;paymentMethod&quot;, selectedPaymentMethod)

def bookingDateTime = LocalDateTime.now().plusDays(random.nextInt(61) - 30)
def appointmentDateTime = LocalDateTime.now().plusDays(random.nextInt(61) - 30)
vars.put(&quot;bookingDateTime&quot;, bookingDateTime.toString())
vars.put(&quot;appointmentDateTime&quot;, appointmentDateTime.toString())

def locationSameAsRegistered = random.nextBoolean()
vars.put(&quot;locationSameAsRegistered&quot;, String.valueOf(locationSameAsRegistered))

def randomRemark = RandomStringUtils.randomAlphabetic(random.nextInt(101))
vars.put(&quot;remarks&quot;, randomRemark)</stringProp>
