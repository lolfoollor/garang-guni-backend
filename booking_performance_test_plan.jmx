        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Randomize Variables" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import org.apache.commons.lang3.RandomStringUtils
import java.time.LocalDateTime
import java.util.Random
import groovy.json.JsonOutput

vars.put(&quot;itemsJson&quot;, JsonOutput.toJson([]))

def collectionTypes = [&quot;HOME&quot;, &quot;COLLECTION_POINT&quot;]
def paymentMethods = [&quot;CREDIT_CARD&quot;, &quot;PAYPAL&quot;, &quot;BANK_TRANSFER&quot;, &quot;CASH&quot;, &quot;VISA&quot;, &quot;MASTER&quot;, &quot;PAYNOW&quot;, &quot;PAYLAH&quot;]
def random = new Random()

def selectedCollectionType = collectionTypes[random.nextInt(collectionTypes.size())]
def selectedPaymentMethod = paymentMethods[random.nextInt(paymentMethods.size())]

vars.put(&quot;collectionType&quot;, selectedCollectionType)
vars.put(&quot;paymentMethod&quot;, selectedPaymentMethod)

def bookingDateTime = LocalDateTime.now().plusDays(random.nextInt(61) - 30)
def appointmentDateTime = LocalDateTime.now().plusDays(random.nextInt(61) - 30)
vars.put(&quot;bookingDateTime&quot;, bookingDateTime.toString())
vars.put(&quot;appointmentDateTime&quot;, appointmentDateTime.toString())

def locationSameAsRegistered = random.nextBoolean()
vars.put(&quot;locationSameAsRegistered&quot;, String.valueOf(locationSameAsRegistered))

def randomRemark = RandomStringUtils.randomAlphabetic(random.nextInt(101))
vars.put(&quot;remarks&quot;, randomRemark)</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <LoopController guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">3</stringProp>
        </LoopController>
        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="generateRandomItem" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import groovy.json.JsonOutput
import groovy.json.JsonSlurper
import java.nio.file.Files
import java.nio.file.Paths
import java.util.Random
import org.apache.commons.lang3.RandomStringUtils

def random = new Random()
// All test photo imgs dir
def IMAGE_DIR = vars.get(&quot;IMAGE_DIR&quot;)

def images = Files.list(Paths.get(IMAGE_DIR))
                 .map { it.toString() }
                 .filter { it.endsWith(&quot;.png&quot;) }
                 .collect()

log.info(&quot;Found ${images.size()} images.&quot;)

def itemName = RandomStringUtils.randomAlphabetic(10)
def itemDescription = RandomStringUtils.randomAlphabetic(35)

log.info(&quot;Generated item: Name = $itemName, Description = $itemDescription&quot;)

def selectedImages = []

def numImages = 3

log.info(&quot;Number of images to select: $numImages&quot;)

for (int i = 0; i &lt; numImages; i++) {
    selectedImages &lt;&lt; images.get(random.nextInt(images.size()))
}

def itemsJson = new groovy.json.JsonSlurper().parseText(vars.get(&quot;itemsJson&quot;))

log.info(&quot;Current itemsJson: $itemsJson&quot;)

itemsJson &lt;&lt; [itemName: itemName, itemDescription: itemDescription, images: selectedImages]
vars.put(&quot;itemsJson&quot;, JsonOutput.toJson(itemsJson))

log.info(&quot;Updated itemsJson: $itemsJson&quot;)
log.info(&quot;itemsJson has been updated in vars.&quot;)</stringProp>
          </JSR223Sampler>
          <hashTree/>
        </hashTree>
